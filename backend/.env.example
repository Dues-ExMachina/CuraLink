# ───────────────────────────────────────────────
# Server Configuration
# ───────────────────────────────────────────────
PORT=5000

# ───────────────────────────────────────────────
# MongoDB Connection String
# Get yours from: https://cloud.mongodb.com
# ───────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/curalink?retryWrites=true&w=majority

# ───────────────────────────────────────────────
# Hugging Face Inference API Key
# Get yours from: https://huggingface.co/settings/tokens
# ───────────────────────────────────────────────
HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ───────────────────────────────────────────────
# HF Model to use for reasoning (open-source)
# Default: mistralai/Mistral-7B-Instruct-v0.3
# Alternatives: meta-llama/Llama-3.1-8B-Instruct
# ───────────────────────────────────────────────
HF_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3

# ───────────────────────────────────────────────
# NCBI PubMed API Key (optional but recommended)
# Get yours from: https://www.ncbi.nlm.nih.gov/account/
# ───────────────────────────────────────────────
PUBMED_API_KEY=

# ───────────────────────────────────────────────
# Frontend URL (for CORS)
# ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
